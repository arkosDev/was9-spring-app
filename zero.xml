<?xml version="1.0" encoding="UTF-8"?>
<jaxb:bindings version="2.0"
               xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
               xmlns:xsd="http://www.w3.org/2001/XMLSchema">

    <!-- Renombra las clases duplicadas directamente con XPath global (más tolerante) -->
    <jaxb:bindings node="//xsd:element[@name='VehicleUploadRequest']">
        <jaxb:class name="VehicleUploadRequest2"/>
    </jaxb:bindings>

    <jaxb:bindings node="//xsd:element[@name='VehicleUploadResponse']">
        <jaxb:class name="VehicleUploadResponse2"/>
    </jaxb:bindings>

    <!-- Si también choca ObjectFactory -->
    <jaxb:bindings node="//xsd:complexType[@name='VehicleUploadRequest']">
        <jaxb:class name="VehicleUploadRequest2"/>
    </jaxb:bindings>

</jaxb:bindings>
