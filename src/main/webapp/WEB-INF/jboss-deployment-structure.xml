<?xml version="1.0" encoding="UTF-8"?>
<jboss-deployment-structure xmlns="urn:jboss:deployment-structure:1.2">
    <deployment>
        <dependencies>
            <!--
                Expone los modulos de Tiles que JBoss EAP 7.4 ya incluye.
                Esto evita el ClassNotFoundException porque el ClassLoader
                del WAR puede ver las clases de Tiles del servidor.
            -->
            <module name="org.apache.tiles" export="true"/>
            <module name="org.apache.tiles.api" export="true"/>
            <module name="org.apache.tiles.core" export="true"/>
            <module name="org.apache.tiles.servlet" export="true"/>
            <module name="org.apache.tiles.jsp" export="true"/>
        </dependencies>
    </deployment>
</jboss-deployment-structure>
