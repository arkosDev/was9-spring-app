<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <constant name="struts.devMode"                       value="false"/>
    <constant name="struts.i18n.encoding"                 value="UTF-8"/>
    <constant name="struts.action.extension"              value="action,"/>
    <constant name="struts.ui.theme"                      value="simple"/>
    <!-- Actions son beans de Spring -->
    <constant name="struts.objectFactory"                 value="spring"/>
    <constant name="struts.objectFactory.spring.autoWire" value="name"/>

    <!-- Paquete base con result-type "tiles" por defecto -->
    <package name="base" namespace="/views" extends="struts-default,tiles-default">

        <!--
            "tiles-default" viene del struts2-tiles-plugin.
            Registra el result-type "tiles" que busca la definicion
            en WEB-INF/tiles/tiles.xml por el nombre indicado en el result.
        -->
        <result-types>
            <result-type name="tiles"
                         class="org.apache.struts2.views.tiles.TilesResult"/>
        </result-types>

        <global-results>
            <result name="error" type="tiles">common.error</r>
        </global-results>
        <global-exception-mappings>
            <exception-mapping exception="java.lang.Exception" result="error"/>
        </global-exception-mappings>

    </package>

    <!-- Productos -->
    <package name="producto" namespace="/views/producto" extends="base">

        <!--
            form-class declara el form bean de cada action
            (equivalente al form-bean de struts-config.xml en Struts 1).
            Los results apuntan a nombres de definicion en tiles.xml.
        -->

        <action name="listar" class="com.empresa.api.struts.action.ProductoAction" method="listar">
            <result name="success" type="tiles">producto.lista</r>
        </action>

        <action name="nuevo" class="com.empresa.api.struts.action.ProductoAction" method="nuevo">
            <param name="form-class">com.empresa.api.struts.form.ProductoForm</param>
            <result name="success" type="tiles">producto.form</r>
        </action>

        <action name="guardar" class="com.empresa.api.struts.action.ProductoAction" method="guardar">
            <param name="form-class">com.empresa.api.struts.form.ProductoForm</param>
            <result name="success" type="redirect">/views/producto/listar.action</r>
            <result name="input"   type="tiles">producto.form</r>
        </action>

        <action name="editar" class="com.empresa.api.struts.action.ProductoAction" method="editar">
            <param name="form-class">com.empresa.api.struts.form.ProductoForm</param>
            <result name="success"  type="tiles">producto.form</r>
            <result name="notFound" type="redirect">/views/producto/listar.action</r>
        </action>

        <action name="eliminar" class="com.empresa.api.struts.action.ProductoAction" method="eliminar">
            <result name="success" type="redirect">/views/producto/listar.action</r>
        </action>

    </package>

</struts>
