<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <constant name="struts.devMode"                       value="false"/>
    <constant name="struts.i18n.encoding"                 value="UTF-8"/>
    <constant name="struts.action.extension"              value="action,"/>
    <constant name="struts.ui.theme"                      value="simple"/>
    <!-- Clave: Actions son beans de Spring -->
    <constant name="struts.objectFactory"                 value="spring"/>
    <constant name="struts.objectFactory.spring.autoWire" value="name"/>

    <!-- Paquete base — namespace /views -->
    <package name="base" namespace="/views" extends="struts-default">

        <global-results>
            <result name="error">/WEB-INF/views/struts/common/error.jsp</result>
        </global-results>
        <global-exception-mappings>
            <exception-mapping exception="java.lang.Exception" result="error"/>
        </global-exception-mappings>

    </package>

    <!-- Productos -->
    <package name="producto" namespace="/views/producto" extends="base">

        <action name="listar" class="com.empresa.api.struts.action.ProductoAction" method="listar">
            <result name="success">/WEB-INF/views/struts/producto/lista.jsp</result>
        </action>

        <action name="nuevo" class="com.empresa.api.struts.action.ProductoAction" method="nuevo">
            <result name="success">/WEB-INF/views/struts/producto/form.jsp</result>
        </action>

        <action name="guardar" class="com.empresa.api.struts.action.ProductoAction" method="guardar">
            <result name="success"  type="redirect">/views/producto/listar.action</result>
            <result name="input">   /WEB-INF/views/struts/producto/form.jsp</result>
        </action>

        <action name="editar" class="com.empresa.api.struts.action.ProductoAction" method="editar">
            <result name="success">/WEB-INF/views/struts/producto/form.jsp</result>
            <result name="notFound" type="redirect">/views/producto/listar.action</result>
        </action>

        <action name="eliminar" class="com.empresa.api.struts.action.ProductoAction" method="eliminar">
            <result name="success" type="redirect">/views/producto/listar.action</result>
        </action>

    </package>

</struts>
